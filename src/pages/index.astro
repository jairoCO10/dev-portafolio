---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-content">
					<h1>Python Backend Developer</h1>
					<p class="subtitle">Construyendo soluciones robustas y escalables</p>
					<p>
						Especializado en desarrollo backend con Python, Php y frameworks modernos como lo son Django FastApi, Laravel.
						Apasionado por crear arquitecturas eficientes y código limpio.
					</p>
				</div>
				<div class="hero-image">
					<img src="IMG_6996.jpg" alt="Developer profile" />
				</div>
			</section>

			<section id="about" class="about">
				<h2>¿Quién Soy?</h2>
				<p>
					Soy un desarrollador backend y especialista en seguridad informatica cuento con más de 3 años de experiencia en Python y php.
					Me especializo en crear APIs RESTful, microservicios y aplicaciones web escalables.
					Mi enfoque se centra en escribir código limpio,seguro, mantenible y bien documentado.
				</p>
				<p>
					Disfruto resolviendo problemas complejos y aprendiendo nuevas tecnologías.
					Actualmente, me encuentro profundizando en arquitecturas cloud-native y DevOps.
				</p>
			</section>

			<section id="repos" class="repos">
				<h2>Repositorios Destacados</h2>
				<div class="repos-grid">
					<div class="repo-card">
						<h3>API InvenTrack</h3>
						<p>es una solución simplificada pero eficiente para la gestión de inventario y ventas, diseñada
							para pequeñas y medianas empresas que necesitan un control preciso sobre sus productos y
							ventas</p>
						<!--<p>⭐ 120 stars</p>-->
						<a href="https://github.com/jairoCO10/InvenTrack" class="btn">Ver en GitHub</a>
					</div>
					<div class="repo-card">
						<h3>microservice-gym</h3>
						<p>api para microservicios de un gym</p>
						<!--<p>⭐ 85 stars</p>-->
						<a href="https://github.com/jairoCO10/microservice-gym" class="btn">Ver en GitHub</a>
					</div>
					<div class="repo-card">
						<h3>FastHtml porfolio</h3>
						<p>portafolio realizado con python usando la librerai de fasthtml</p>
						<!--<p>⭐ 95 stars</p>-->
						<a href="https://github.com/jairoCO10/py-portfolio" class="btn">Ver en GitHub</a>
					</div>
					<!--<div class="repo-card">-->
					<!--	<h3>FastAPI Utils</h3>-->
					<!--	<p>Utilidades y middlewares para FastAPI</p>-->
					<!--	<p>⭐ 95 stars</p>-->
					<!--	<a href="#" class="btn">Ver en GitHub</a>-->
					<!--</div>-->
					<!--<div class="repo-card">-->
					<!--	<h3>FastAPI Utils</h3>-->
					<!--	<p>Utilidades y middlewares para FastAPI</p>-->
					<!--	<p>⭐ 95 stars</p>-->
					<!--	<a href="#" class="btn">Ver en GitHub</a>-->
					<!--</div>-->
				</div>
			</section>

			<section id="projects" class="projects">
				<h2>Proyectos Profesionales</h2>
				<div class="project-grid">
					<article class="project-card">
						<h3>Sistema de Pagos</h3>
						<p>Plataforma de procesamiento de pagos con integración multi-gateway</p>
